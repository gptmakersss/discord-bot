# =======================
# Discord intents
# =======================
intents = discord.Intents.default()
intents.message_content = True

bot = commands.Bot(command_prefix="!", intents=intents)

# expose config to cogs
bot.GUILD_ID = GUILD_ID
bot.guild_obj = discord.Object(id=GUILD_ID)
bot.CHANNELS = CHANNELS

# =======================
# Helpers
# =======================
async def _get_channel(channel_id: int):
    ch = bot.get_channel(channel_id)
    if ch:
        return ch
    try:
        return await bot.fetch_channel(channel_id)
    except Exception:
        return None


async def send_log(title: str, details: str):
    ch_id = bot.CHANNELS.get("logs")
    if not ch_id:
        return
    ch = await _get_channel(ch_id)
    if not ch:
        return

    embed = discord.Embed(title=title, description=details)
    await ch.send(embed=embed)


bot.send_log = send_log

