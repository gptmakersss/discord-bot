# =======================
# Events
# =======================
@bot.event
async def on_ready():
    print(f"✅ Logged in as {bot.user}")
    try:
        synced = await bot.tree.sync(guild=bot.guild_obj)
        print(f"✅ Synced {len(synced)} slash commands")
    except Exception as e:
        print("❌ Sync error:", e)


async def load_cogs():
    for ext in EXTENSIONS:
        try:
            await bot.load_extension(ext)
            print(f"✅ Loaded {ext}")
        except Exception as e:
            print(f"❌ Failed loading {ext}: {e}")


async def main():
    if "PASTE_YOUR_DISCORD_BOT_TOKEN_HERE" in TOKEN:
        raise RuntimeError("❌ לא הכנסת טוקן לבוט")

    async with bot:
        await load_cogs()
        await bot.start(TOKEN)


if __name__ == "__main__":
    asyncio.run(main())
